{
    "name": "s7codedesign/dexpress-woocommerce",
    "description": "D Express courier service integration for WooCommerce",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "S7codedesign\\DExpress\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "S7codedesign\\DExpress\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable"
}
